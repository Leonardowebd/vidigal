{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "deploy/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Century Schoolbook|Montserrat))/i]",
        "message": "Font not provided by the design system. Available: Century Schoolbook, Montserrat."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|secondary-onlight)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'secondary-onlight'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|sm)$/]",
        "message": "<Button> size must be one of 'lg' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:photo|eyebrow|heading|body|panelTone|panelAlign|height|key|ref|className|style|children)$/]",
        "message": "<FeatureCard> doesn't accept that prop. Declared props: photo, eyebrow, heading, body, panelTone, panelAlign, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute[name.name='panelTone'] > Literal[value!=/^(?:cream|olive)$/]",
        "message": "<FeatureCard> panelTone must be one of 'cream' | 'olive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute[name.name='panelAlign'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<FeatureCard> panelAlign must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:photo|logo|signature|navLinks|contact|address|tagline|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: photo, logo, signature, navLinks, contact, address, tagline."
      },
      {
        "selector": "JSXOpeningElement[name.name='Navbar'] > JSXAttribute > JSXIdentifier[name!=/^(?:logo|links|ctaLabel|tone|key|ref|className|style|children)$/]",
        "message": "<Navbar> doesn't accept that prop. Declared props: logo, links, ctaLabel, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Navbar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<Navbar> tone must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhotoTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|radius|key|ref|className|style|children)$/]",
        "message": "<PhotoTile> doesn't accept that prop. Declared props: src, alt, radius."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionIntro'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|heading|body|tone|maxWidth|key|ref|className|style|children)$/]",
        "message": "<SectionIntro> doesn't accept that prop. Declared props: eyebrow, heading, body, tone, maxWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionIntro'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|light)$/]",
        "message": "<SectionIntro> tone must be one of 'dark' | 'light'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Button": {
        "replaces": []
